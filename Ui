    SkinsTab:AddSection({Name = "تغيير سريع"})
    local customSkin = ""
    SkinsTab:AddTextbox({Name = "اكتب يوزر أي لاعب", Default = "", Callback = function(Value) customSkin = Value end})
    SkinsTab:AddButton({Name = "لبس السكن المكتوب", Callback = function() if customSkin ~= "" then pcall(function() game:GetService("ReplicatedStorage").ChangeSkin:FireServer(unpack({[1] = customSkin})) end) end end})

