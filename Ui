        Logic.TargetPlayers = {}
        TargetsDisplay:Set("📋 الضحايا المحددين حالياً:", "لا يوجد ضحايا")
        OrionLib:MakeNotification({Name = "تنظيف", Content = "تم مسح قائمة الضحايا بنجاح!", Image = "rbxassetid://4483345998", Time = 3})
    end})

