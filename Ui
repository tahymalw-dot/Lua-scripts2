    local PlayerDropdown = ReadySpamTab:AddDropdown({Name = "اختر لاعب من السيرفر", Options = {}, Callback = function(Value) CurrentSelectedPlayer = Value end})

    local function UpdatePlayerDropdown()
        local playerNames = {}
        for _, player in pairs(game.Players:GetPlayers()) do
            if player ~= game.Players.LocalPlayer then table.insert(playerNames, player.Name) end
