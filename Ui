        SectionTitle.Size = UDim2.new(1, 0, 0.1, 0)
        SectionTitle.BackgroundTransparency = 1
        SectionTitle.Text = name
        SectionTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
        SectionTitle.TextScaled = true
        SectionTitle.Font = Enum.Font.GothamBold
        
        local Scroll = Instance.new("ScrollingFrame", SectionFrame)
        Scroll.Size = UDim2.new(1, -10, 0.9, -10)
        Scroll.Position = UDim2.new(0, 5, 0.1, 0)
        Scroll.BackgroundTransparency = 1
        Scroll.CanvasSize = UDim2.new(0, 0, 5, 0)
        Scroll.ScrollBarThickness = 4
        
        local Grid = Instance.new("UIGridLayout", Scroll)
        Grid.CellSize = UDim2.new(0, 80, 0, 80)
        Grid.CellPadding = UDim2.new(0, 10, 0, 10)
        
        for _, user in ipairs(usernames) do
