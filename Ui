    ReadySpamTab:AddToggle({Name = "⚡ تشغيل النسخ الثاني", Default = false, Callback = function(V) s2E[1] = V; if V then Logic.StartProSpam(s2C, s2E, 3) end end})

    ReadySpamTab:AddSection({Name = "👑 ═══ أوامر الهيد ادمن (Head Admin) ═══ 👑"})
    ReadySpamTab:AddToggle({Name = "🔥 تشغيل النسخ الثالث", Default = false, Callback = function(V) s3E[1] = V; if V then Logic.StartProSpam(s3C, s3E, 3) end end})
    ReadySpamTab:AddToggle({Name = "🔥 تشغيل النسخ الرابع", Default = false, Callback = function(V) s4E[1] = V; if V then Logic.StartProSpam(s4C, s4E, 3) end end})

