    ExtraTab:AddSection({Name = "نظام التايتل (Title)"})
    local titleText = ""
    local selectedColor = Color3.fromRGB(255, 255, 255)
    local isRainbow = false
    ExtraTab:AddTextbox({Name = "اكتب التايتل", Default = "", Callback = function(Value) titleText = Value end})
