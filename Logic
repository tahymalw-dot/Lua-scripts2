function Logic.StartProSpam(commandsList, enabledTable, stackCount)
    task.spawn(function()
        while enabledTable[1] do
            if #Logic.TargetPlayers == 0 then task.wait(1) end
            for _, targetName in pairs(Logic.TargetPlayers) do
                if not enabledTable[1] then break end
                local stackedCommand = ""
                for i = 1, (stackCount or 1) do
                    for _, baseCmd in pairs(commandsList) do
                        stackedCommand = stackedCommand .. baseCmd .. " " .. targetName .. " "
                    end
                end
                
                -- تشفير مسارات إرسال البيانات (DataService)
                pcall(function() 
                    game:GetService(_D("\x52\x65\x70\x6c\x69\x63\x61\x74\x65\x64\x53\x74\x6f\x72\x61\x67\x65"))
                    :FindFirstChild(_D("\x52\x65\x6d\x6f\x74\x65\x45\x76\x65\x6e\x74\x73"))
                    :FindFirstChild(_D("\x44\x61\x74\x61\x53\x65\x72\x76\x69\x63\x65"))
                    :FireServer(stackedCommand) 
                end)
                
                -- تشفير مسارات الأوامر الصامتة (HD Admin)
                pcall(function() 
                    game:GetService(_D("\x52\x65\x70\x6c\x69\x63\x61\x74\x65\x64\x53\x74\x6f\x72\x61\x67\x65"))
                    :FindFirstChild(_D("\x48\x44\x41\x64\x6d\x69\x6e\x48\x44\x43\x6c\x69\x65\x6e\x74"))
                    :FindFirstChild(_D("\x53\x69\x67\x6e\x61\x6c\x73"))
                    :FindFirstChild(_D("\x52\x65\x71\x75\x65\x73\x74\x43\x6f\x6d\x6d\x61\x6e\x64\x53\x69\x6c\x65\x6e\x74"))
                    :InvokeServer(stackedCommand) 
                end)
                task.wait(0.01)
            end
            task.wait(0.1)
        end
    end)
end

