        local NameText = Instance.new("TextLabel", Frame)
        NameText.Size = UDim2.new(0, 300, 0, 50)
        NameText.Position = UDim2.new(0, 130, 0, 20)
        NameText.Text = t.User .. " | " .. t.ID
        NameText.TextColor3 = Color3.white
        NameText.Font = Enum.Font.GothamBold
        NameText.BackgroundTransparency = 1

        local ContentText = Instance.new("TextLabel", Frame)
        ContentText.Size = UDim2.new(0, 410, 0, 100)
        ContentText.Position = UDim2.new(0, 20, 0, 130)
        ContentText.Text = t.Content
        ContentText.TextColor3 = Color3.fromRGB(200, 200, 200)
        ContentText.TextWrapped = true
        ContentText.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        Instance.new("UICorner", ContentText)

        local CloseBtn = Instance.new("TextButton", Frame)
        CloseBtn.Text = "إغلاق النافذة"
        CloseBtn.Size = UDim2.new(0, 100, 0, 40)
        CloseBtn.Position = UDim2.new(0.5, -50, 0.85, 0)
        CloseBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)
    end

    -- // التبويب
    local SupportTab = Window:MakeTab({Name = "🎫 Arab Hub Support", Icon = "rbxassetid://11429532655"})

    -- قسم إرسال الطلب (للجميع)
    SupportTab:AddSection({Name = "✨ إرسال اقتراح"})
    local InputText = ""
    SupportTab:AddTextbox({Name = "اكتب اقتراحك هنا...", Default = "", Callback = function(v) InputText = v end})
    SupportTab:AddButton({
        Name = "🚀 إرسال الطلب للمطورين",
        Callback = function()
            if #InputText < 5 then return end
            local ID = "AH-" .. math.random(1000, 9999)
            table.insert(Logic.Tickets, {ID = ID, User = LocalPlayer.Name, UserId = LocalPlayer.UserId, Content = InputText, Status = "⏳ قيد المراجعة"})
            OrionLib:MakeNotification({Name = "تم الإرسال!", Content = "رقم التذكرة: " .. ID, Time = 3})
        end
    })

    -- قسم المطور (يظهر فقط لـ tatitoyo89)
    if LocalPlayer.Name == "tatitoyo89" then
        SupportTab:AddSection({Name = "👑 لوحة تحكم المطور"})
        
        local SelectedTicket = nil
        local Dropdown = SupportTab:AddDropdown({Name = "اختر تذكرة للتحكم", Options = {"اضغط تحديث أولاً"}, Callback = function(v) 
            SelectedTicket = string.match(v, "AH%-%d+") 
        end})

        SupportTab:AddButton({Name = "🔄 تحديث القائمة", Callback = function()
            local list = {}
            for _, t in pairs(Logic.Tickets) do table.insert(list, t.ID .. " | " .. t.User) end
            if #list == 0 then list = {"لا توجد طلبات"} end
            Dropdown:Refresh(list, true)
        end})

        SupportTab:AddButton({Name = "👁️ عرض التفاصيل الأسطورية", Callback = function()
            if not SelectedTicket then return end
            for _, t in pairs(Logic.Tickets) do
                if t.ID == SelectedTicket then CreateLegendaryGUI(t) end
            end
        end})

        SupportTab:AddButton({Name = "✅ قبول الطلب", Callback = function()
            for _, t in pairs(Logic.Tickets) do if t.ID == SelectedTicket then t.Status = "✅ مقبول" end end
            OrionLib:MakeNotification({Name = "تم", Content = "تم قبول التذكرة", Time = 3})
        end})
    end
end


return Logic
