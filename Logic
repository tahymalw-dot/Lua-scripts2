            Callback = function()
                if not SelectedTicketID then return end
                for _, t in pairs(Logic.AllTickets) do
                    if t.ID == SelectedTicketID then ShowTicketDetailGUI(t) break end
                end
            end
        })

        local function UpdateTicketStatus(newStatus)
            if not SelectedTicketID then return end
            for _, t in pairs(Logic.AllTickets) do
                if t.ID == SelectedTicketID then
                    t.Status = newStatus
                    OrionLib:MakeNotification({Name = "تم التحديث", Content = "أصبحت الحالة: " .. newStatus, Time = 3})
                    break
                end
            end
        end

        DevTab:AddButton({Name = "✅ قبول", Callback = function() UpdateTicketStatus("✅ مقبول") end})
        DevTab:AddButton({Name = "❌ رفض", Callback = function() UpdateTicketStatus("❌ مرفوض") end})
        DevTab:AddButton({Name = "⏳ قيد المراجعة", Callback = function() UpdateTicketStatus("⏳ قيد المراجعة") end})
    end
end
        

