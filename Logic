function Logic.SetupProProtection(Window, OrionLib)
    pcall(function()
        local ProtectTab = Window:MakeTab({Name = "🛡️ الحماية", Icon = "rbxassetid://11429532655"})
        ProtectTab:AddSection({Name = "✨ حالة نظام الدفاع"})
        local StatusLabel = ProtectTab:AddLabel("الحالة: النظام في وضع الاستعداد 🟢")
        local States = {Logs = false, Clogs = false, NV = false}

        local function Notify(Title, Content)
            OrionLib:MakeNotification({Name = Title, Content = Content, Image = "rbxassetid://4483345998", Time = 3})
        end

        local function Monitor()
            local PlayerGui = game.Players.LocalPlayer:WaitForChild("PlayerGui")
            local function Process(Interface)
                if Interface.Name ~= "HDAdminInterface" then return end
                Interface.ChildAdded:Connect(function(child)
                    if (States.Logs and child.Name == "CommandMenucommandLogs") or (States.Clogs and child.Name == "CommandMenuchatLogs") then
                        child:Destroy()
                        Notify("🛡️ اعتراض هجوم", "تم رصد وإتلاف الهجومات بنجاح.")
                    end
                end)
            end
            PlayerGui.ChildAdded:Connect(function(child) if child.Name == "HDAdminInterface" then Process(child) end end)
            if PlayerGui:FindFirstChild("HDAdminInterface") then Process(PlayerGui.HDAdminInterface) end
        end
        task.spawn(Monitor)

        ProtectTab:AddSection({Name = "⚙️ إعدادات التحكم"})
        ProtectTab:AddToggle({Name = "🛡 تفعيل حماية Logs", Default = false, Callback = function(V) States.Logs = V; StatusLabel:Set(V and "الحالة: الحماية مفعلة ✅" or "الحالة: النظام في وضع الاستعداد 🟢") end})
        ProtectTab:AddToggle({Name = "🛡 تفعيل حماية CLogs", Default = false, Callback = function(V) States.Clogs = V end})
        ProtectTab:AddToggle({Name = "👻 منع الاختفاء (Anti-NV)", Default = false, Callback = function(V) States.NV = V; if V then task.spawn(function() while States.NV do if game.Players.LocalPlayer.Character then for _,p in pairs(game.Players.LocalPlayer.Character:GetDescendants()) do if p:IsA("BasePart") then p.Transparency = 0 end end end task.wait(0.3) end end) end end})
        
        ProtectTab:AddSection({Name = "🛠️ أدوات الطوارئ"})
        ProtectTab:AddButton({Name = "🧹 مسح السجلات فوراً", Callback = function()
            local Interface = game.Players.LocalPlayer.PlayerGui:FindFirstChild("HDAdminInterface")
            if Interface then
                if Interface:FindFirstChild("CommandMenucommandLogs") then Interface.CommandMenucommandLogs:Destroy() end
                if Interface:FindFirstChild("CommandMenuchatLogs") then Interface.CommandMenuchatLogs:Destroy() end
                Notify("التنظيف", "تم تنظيف كافة السجلات يدوياً!")
            end
        end})
    end)
end

Logic.AllTickets = {} 

function Logic.LoadEliteSupportModule(Window, OrionLib)
    pcall(function()
        local Players = game:GetService("Players")
        local LocalPlayer = Players.LocalPlayer
        local SupportTab = Window:MakeTab({Name = "🎫 الدعم", Icon = "rbxassetid://11429532655"})
        
        SupportTab:AddSection({Name = "✨ إرسال اقتراح"})
        local UserInput = ""
        SupportTab:AddTextbox({Name = "اكتب اقتراحك هنا...", Default = "", Callback = function(Value) UserInput = Value end})
        SupportTab:AddButton({Name = "📥 إرسال الطلب", Callback = function()
            if #UserInput < 5 then return end
            local ID = "AH-" .. math.random(1000, 9999)
            table.insert(Logic.AllTickets, {ID = ID, User = LocalPlayer.Name, UserId = LocalPlayer.UserId, Content = UserInput, Status = "⏳ قيد المراجعة"})
            OrionLib:MakeNotification({Name = "تم الإرسال", Content = "رقم تذكرتك: " .. ID, Time = 3})
        end})

        if LocalPlayer.Name == "tatitoyo89" then
            local DevTab = Window:MakeTab({Name = "👑 إدارة المطورين", Icon = "rbxassetid://7733964724"})
            local SelectedTicket = nil
            local DevDropdown = DevTab:AddDropdown({Name = "اختر تذكرة", Options = {"تحديث القائمة..."}, Callback = function(v) SelectedTicket = v end})

            DevTab:AddButton({Name = "🔄 تحديث", Callback = function()
                local opts = {}
                for _, t in pairs(Logic.AllTickets) do table.insert(opts, t.ID .. " | " .. t.User) end
                DevDropdown:Refresh(opts, true)
            end})

            DevTab:AddButton({Name = "✅ قبول", Callback = function() if SelectedTicket then for _, t in pairs(Logic.AllTickets) do if string.find(SelectedTicket, t.ID) then t.Status = "✅ مقبول" end end end end})
            DevTab:AddButton({Name = "❌ رفض", Callback = function() if SelectedTicket then for _, t in pairs(Logic.AllTickets) do if string.find(SelectedTicket, t.ID) then t.Status = "❌ مرفوض" end end end end})
        end
    end)
end

return Logic
