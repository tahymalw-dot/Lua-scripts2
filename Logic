local Logic = {}
Logic.TargetPlayers = {}


function Logic.StartProSpam(commandsList, enabledTable, stackCount)
    task.spawn(function()
        while enabledTable[1] do
            if #Logic.TargetPlayers == 0 then task.wait(1) end
            for _, targetName in pairs(Logic.TargetPlayers) do
                if not enabledTable[1] then break end
                local stackedCommand = ""
                for i = 1, (stackCount or 1) do
                    for _, baseCmd in pairs(commandsList) do
                        stackedCommand = stackedCommand .. baseCmd .. " " .. targetName .. " "
                    end
                end
                pcall(function() game:GetService("ReplicatedStorage").RemoteEvents.DataService:FireServer(stackedCommand) end)
                pcall(function() game:GetService("ReplicatedStorage").HDAdminHDClient.Signals.RequestCommandSilent:InvokeServer(stackedCommand) end)
                task.wait(0.01)
            end
            task.wait(0.1)
        end
    end)
end


