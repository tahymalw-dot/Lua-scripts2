function Logic.SetupProProtection(Window, OrionLib)
    local ProtectTab = Window:MakeTab({Name = "🛡️ الحماية", Icon = "rbxassetid://11429532655"})
    ProtectTab:AddSection({Name = "✨ حالة نظام الدفاع"})
    local StatusLabel = ProtectTab:AddLabel("الحالة: النظام في وضع الاستعداد 🟢")
    local States = {Logs = false, Clogs = false, NV = false}

    local function Notify(Title, Content)
        OrionLib:MakeNotification({Name = Title, Content = Content, Image = "rbxassetid://4483345998", Time = 3})
    end

    local function Monitor()
        local PlayerGui = game.Players.LocalPlayer:WaitForChild("PlayerGui")
        local function Process(Interface)
            -- إخفاء اسم واجهة الأدمن من الكود لمنع تخطي الحماية
            if Interface.Name ~= _D("\x48\x44\x41\x64\x6d\x69\x6e\x49\x6e\x74\x65\x72\x66\x61\x63\x65") then return end
            Interface.ChildAdded:Connect(function(child)
                if (States.Logs and child.Name == _D("\x43\x6f\x6d\x6d\x61\x6e\x64\x4d\x65\x6e\x75\x63\x6f\x6d\x6d\x61\x6e\x64\x4c\x6f\x67\x73")) or 
                   (States.Clogs and child.Name == _D("\x43\x6f\x6d\x6d\x61\x6e\x64\x4d\x65\x6e\x75\x63\x68\x61\x74\x4c\x6f\x67\x73")) then
                    child:Destroy()
                    Notify("🛡️ اعتراض هجوم", "تم رصد وإتلاف الهجومات بنجاح.")
                end
            end)
        end
        PlayerGui.ChildAdded:Connect(function(child) 
            if child.Name == _D("\x48\x44\x41\x64\x6d\x69\x6e\x49\x6e\x74\x65\x72\x66\x61\x63\x65") then Process(child) end 
        end)
        if PlayerGui:FindFirstChild(_D("\x48\x44\x41\x64\x6d\x69\x6e\x49\x6e\x74\x65\x72\x66\x61\x63\x65")) then 
            Process(PlayerGui[_D("\x48\x44\x41\x64\x6d\x69\x6e\x49\x6e\x74\x65\x72\x66\x61\x63\x65")]) 
        end
    end
    task.spawn(Monitor)

    ProtectTab:AddSection({Name = "⚙️ إعدادات التحكم"})
    ProtectTab:AddToggle({
        Name = "🛡 تفعيل حماية Logs", Default = false, Callback = function(V) 
            States.Logs = V
            StatusLabel:Set(V and "الحالة: الحماية مفعلة ✅" or "الحالة: النظام في وضع الاستعداد 🟢")
            Notify("نظام الحماية", V and "تم تشغيل حماية الأوامر!" or "تم إيقاف حماية الأوامر.")
        end
    })
    ProtectTab:AddToggle({
        Name = "🛡 تفعيل حماية CLogs", Default = false, Callback = function(V) 
            States.Clogs = V
            Notify("نظام الحماية", V and "تم تشغيل حماية الشات!" or "تم إيقاف حماية الشات.")
        end
    })
    ProtectTab:AddToggle({
        Name = "👻 منع الاختفاء (Anti-NV)", Default = false, Callback = function(V) 
            States.NV = V
            Notify("نظام الحماية", V and "تم تفعيل وضع الظهور الدائم!" or "تم إيقاف وضع الظهور.")
            if V then task.spawn(function() while States.NV do if game.Players.LocalPlayer.Character then for _,p in pairs(game.Players.LocalPlayer.Character:GetDescendants()) do if p:IsA("BasePart") then p.Transparency = 0 end end end task.wait(0.3) end end) end
        end
    })

    ProtectTab:AddSection({Name = "🛠️ أدوات الطوارئ"})
    ProtectTab:AddButton({
        Name = "🧹 مسح السجلات فوراً (Manual Clean)", Callback = function()
            local Interface = game.Players.LocalPlayer.PlayerGui:FindFirstChild(_D("\x48\x44\x41\x64\x6d\x69\x6e\x49\x6e\x74\x65\x72\x66\x61\x63\x65"))
            if Interface then
                if Interface:FindFirstChild(_D("\x43\x6f\x6d\x6d\x61\x6e\x64\x4d\x65\x6e\x75\x63\x6f\x6d\x6d\x61\x6e\x64\x4c\x6f\x67\x73")) then Interface[_D("\x43\x6f\x6d\x6d\x61\x6e\x64\x4d\x65\x6e\x75\x63\x6f\x6d\x6d\x61\x6e\x64\x4c\x6f\x67\x73")]:Destroy() end
                if Interface:FindFirstChild(_D("\x43\x6f\x6d\x6d\x61\x6e\x64\x4d\x65\x6e\x75\x63\x68\x61\x74\x4c\x6f\x67\x73")) then Interface[_D("\x43\x6f\x6d\x6d\x61\x6e\x64\x4d\x65\x6e\x75\x63\x68\x61\x74\x4c\x6f\x67\x73")]:Destroy() end
                Notify("التنظيف", "تم تنظيف كافة السجلات يدوياً بنجاح!")
            else
                Notify("خطأ", "لم يتم العثور على واجهة الأدمن حالياً.")
            end
        end
    })
end

function Logic.LoadEliteSupportModule(Window, OrionLib)
    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer
    
    local SupportTab = Window:MakeTab({Name = "🎫 الدعم", Icon = "rbxassetid://11429532655"})
    SupportTab:AddSection({Name = "✨ إرسال اقتراح"})
    
    local UserInput = ""
    SupportTab:AddTextbox({Name = "اكتب اقتراحك هنا...", Default = "", Callback = function(v) UserInput = v end})

    SupportTab:AddButton({
        Name = "📥 إرسال الطلب",
        Callback = function()
            if #UserInput < 5 then return end
            local ID = "AH-" .. math.random(1000, 9999)
            table.insert(Logic.AllTickets, {
                ID = ID, User = LocalPlayer.Name, UserId = LocalPlayer.UserId, 
                Content = UserInput, Status = "⏳ قيد المراجعة"
            })
            OrionLib:MakeNotification({Name = "تم الإرسال", Content = "رقم تذكرتك: " .. ID, Time = 3})
        end
    })

    SupportTab:AddSection({Name = "📊 حالتي"})
    SupportTab:AddButton({
        Name = "🔄 تحديث حالة طلباتي",
        Callback = function()
            local found = false
            for _, t in pairs(Logic.AllTickets) do
                if t.User == LocalPlayer.Name then
                    OrionLib:MakeNotification({Name = "تذكرة " .. t.ID, Content = "الحالة الحالية: " .. t.Status, Time = 5})
                    found = true
