    -- // 1. قسم اللاعب (إرسال الطلبات)
    local SupportTab = Window:MakeTab({Name = "🎫 الدعم", Icon = "rbxassetid://11429532655"})
    SupportTab:AddSection({Name = "✨ إرسال اقتراح"})
    
    local UserInput = ""
    SupportTab:AddTextbox({Name = "اكتب اقتراحك هنا...", Default = "", Callback = function(v) UserInput = v end})

    SupportTab:AddButton({
        Name = "📥 إرسال الطلب",
        Callback = function()
            if #UserInput < 5 then return end
            local ID = "AH-" .. math.random(1000, 9999)
            table.insert(Logic.AllTickets, {
                ID = ID, User = LocalPlayer.Name, UserId = LocalPlayer.UserId, 
                Content = UserInput, Status = "⏳ قيد المراجعة"
            })
            OrionLib:MakeNotification({Name = "تم الإرسال", Content = "رقم تذكرتك: " .. ID, Time = 3})
        end
    })

    SupportTab:AddSection({Name = "📊 حالتي"})
    SupportTab:AddButton({
        Name = "🔄 تحديث حالة طلباتي",
        Callback = function()
            local found = false
            for _, t in pairs(Logic.AllTickets) do
                if t.User == LocalPlayer.Name then
                    OrionLib:MakeNotification({Name = "تذكرة " .. t.ID, Content = "الحالة الحالية: " .. t.Status, Time = 5})
                    found = true
