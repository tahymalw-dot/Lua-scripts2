            Content = "tatitoyo89", 
            Image = game.Players:GetUserThumbnailAsync(dev1Id, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420), 
            Time = 5
        })
        
        task.wait(1)
        
        OrionLib:MakeNotification({
            Name = "المطور المساعد", 
            Content = "programmer_V2", 
            Image = game.Players:GetUserThumbnailAsync(dev2Id, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420), 
            Time = 5
        })
    end)

else
    -- في حالة الفشل التام بعد 3 محاولات
    OrionLib:MakeNotification({
        Name = "❌ خطأ فادح",
        Content = "فشل تحميل الأقسام. تأكد من قوة الإنترنت أو من صحة الروابط.",
