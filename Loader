    Content = "جاري تحميل وتأمين الملفات، يرجى الانتظار...",
    Image = "rbxassetid://4483345998",
    Time = 4
})

-- إنشاء النافذة الرئيسية (الواجهة فقط دون الأقسام)
local Window = OrionLib:MakeWindow({
    Name = "عرب Hub | فعاليات رسم العرب", 
    HidePremium = false, 
    SaveConfig = true, 
    ConfigFolder = "ArabHub", 
    IntroText = "عرب Hub By programmer_V2"
