-- =========================================================
-- ⚠️ الروابط (ضع روابطك هنا)
-- =========================================================
local LogicURL = "https://raw.githubusercontent.com/tahymalw-dot/Lua-scripts2/refs/heads/main/Logic"
local UiURL = "https://raw.githubusercontent.com/tahymalw-dot/Lua-scripts2/refs/heads/main/Ui"

-- =========================================================
-- ⚙️ نظام التحميل العبقري (محاولات + كسر كاش + انتظار صارم)
-- =========================================================
local function SecureLoad(url, moduleName)
    local result = nil
    local maxRetries = 3 -- عدد المحاولات إذا فشل النت
    
    for i = 1, maxRetries do
        -- كسر الكاش بإضافة tick() لضمان جلب أحدث تحديث دائماً
        local safeUrl = url .. "?v=" .. tostring(tick())
        
        local success, res = pcall(function()
            return loadstring(game:HttpGet(safeUrl))()
        end)
        
        if success and res then
            result = res
            break -- نجح التحميل، نخرج من حلقة المحاولات
        else
            warn("⚠️ تأخير في تحميل " .. moduleName .. " (محاولة " .. i .. " من " .. maxRetries .. ")")
            if i < maxRetries then
                task.wait(1.5) -- انتظار ثانية ونصف قبل المحاولة التالية
            end
        end
    end
    
    return result
end

-- =========================================================
-- ⏳ تحميل الملفات مع إيقاف السكربت حتى تكتمل
-- =========================================================
local Logic = SecureLoad(LogicURL, "ملف Logic")
local UI = SecureLoad(UiURL, "ملف UI")

-- =========================================================
-- 🏗️ بناء السكربت فقط إذا اكتمل التحميل 100%
-- =========================================================
if Logic and type(Logic) == "table" and UI and type(UI) == "table" then
    
    -- 1. بناء واجهة المستخدم (تأخذ المتغيرات والمنطق)
    local successUI, errorUI = pcall(function()
        UI.Build(Window, OrionLib, Logic)
    end)
    if not successUI then warn("❌ خطأ أثناء بناء أقسام UI: " .. tostring(errorUI)) end

    -- 2. تشغيل وظائف الحماية والدعم الخاصة بالمنطق
    local successLogic, errorLogic = pcall(function()
        Logic.SetupProProtection(Window, OrionLib)
        Logic.LoadEliteSupportModule(Window, OrionLib)
    end)
    if not successLogic then warn("❌ خطأ أثناء تشغيل وظائف Logic: " .. tostring(errorLogic)) end

    -- 3. إنهاء البناء وتشغيل الواجهة بنجاح
    OrionLib:Init()
    
    -- =========================================================
    -- ✨ إشعارات الترحيب (تعمل فقط إذا تم كل شيء بنجاح)
